---
const { site, featured = false } = Astro.props;
---

<article class={`group overflow-hidden rounded-[30px] border border-line bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-agency ${featured ? 'lg:col-span-1' : ''}`}>
  <div class="relative aspect-[16/10] overflow-hidden bg-navy">
    <img
      src={site.image}
      alt={`${site.name} sample website screenshot`}
      class="h-full w-full object-cover object-top transition duration-500 group-hover:scale-105"
      loading="lazy"
    />
    <div class={`absolute right-4 top-4 rounded-full px-3 py-1 text-xs font-black uppercase tracking-[0.14em] ${site.live ? 'bg-lime text-midnight' : 'bg-white text-navy'}`}>
      {site.live ? 'Live' : 'Coming soon'}
    </div>
  </div>
  <div class="space-y-4 p-6">
    <div>
      <p class="text-xs font-black uppercase tracking-[0.16em] text-electric">{site.industry}</p>
      <h3 class="mt-3 font-display text-2xl font-black text-navy">{site.name}</h3>
    </div>
    <p class="text-sm font-bold text-navy/72">{site.style}</p>
    <p class="text-sm leading-7 text-slatebody">{site.description}</p>
    <div class="flex flex-col gap-3 sm:flex-row">
      {site.live ? (
        <a href={site.url} target="_blank" rel="noreferrer" class="btn-light">View Site</a>
      ) : (
        <span class="inline-flex min-h-12 items-center justify-center rounded-full border border-line bg-fog px-6 py-3 text-sm font-black text-slatebody">Coming Soon</span>
      )}
    </div>
  </div>
</article>
