---
const { eyebrow, title, copy, align = 'left', light = false } = Astro.props;
const centered = align === 'center';
---

<div class={`${centered ? 'mx-auto max-w-3xl text-center' : 'max-w-3xl'}`}>
  {eyebrow && <p class={light ? 'text-xs font-black uppercase tracking-[0.18em] text-lime' : 'eyebrow'}>{eyebrow}</p>}
  <h2 class={`${light ? 'text-white' : 'text-navy'} mt-4 font-display text-4xl font-black leading-tight tracking-normal sm:text-5xl`}>
    {title}
  </h2>
  {copy && <p class={`${light ? 'text-white/66' : 'text-slatebody'} mt-5 text-lg leading-8`}>{copy}</p>}
</div>
