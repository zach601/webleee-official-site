---
const { title = 'Want to see what your business website could look like?', copy = 'Send the details Webleee needs to prepare a homepage preview or proposal, then review the direction before deciding on the full build.' } = Astro.props;
---

<section class="bg-midnight py-20 text-white">
  <div class="site-shell grid gap-8 border-y border-white/10 py-10 lg:grid-cols-[1fr_0.7fr] lg:items-center">
    <div>
      <p class="text-xs font-black uppercase tracking-[0.18em] text-lime">Website quote</p>
      <h2 class="mt-4 max-w-4xl font-display text-4xl font-black leading-tight sm:text-5xl">{title}</h2>
      <p class="mt-5 max-w-2xl text-lg leading-8 text-white/66">{copy}</p>
    </div>
    <div class="flex flex-col gap-3 sm:flex-row lg:justify-end">
      <a href="/contact/" class="btn-primary">Get a free homepage preview</a>
      <a href="/our-work/" class="btn-secondary">View demo websites</a>
    </div>
  </div>
</section>
