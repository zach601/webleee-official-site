---
const { title = 'Ready to talk about your business website?', copy = 'Send the details Webleee needs to understand the website scope, pages, launch needs, and monthly management requirements.' } = Astro.props;
---

<section class="bg-midnight py-20 text-white">
  <div class="site-shell grid gap-8 lg:grid-cols-[1fr_0.7fr] lg:items-center">
    <div>
      <p class="text-xs font-black uppercase tracking-[0.18em] text-lime">Website quote</p>
      <h2 class="mt-4 max-w-4xl font-display text-4xl font-black leading-tight sm:text-5xl">{title}</h2>
      <p class="mt-5 max-w-2xl text-lg leading-8 text-white/66">{copy}</p>
    </div>
    <div class="flex flex-col gap-3 sm:flex-row lg:justify-end">
      <a href="/contact/" class="btn-primary">Request a website quote</a>
      <a href="/our-work/" class="btn-on-dark">View sample websites</a>
    </div>
  </div>
</section>
