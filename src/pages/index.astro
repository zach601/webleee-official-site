---
import SiteLayout from '../layouts/SiteLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PortfolioCard from '../components/PortfolioCard.astro';
import PricingCards from '../components/PricingCards.astro';
import CTA from '../components/CTA.astro';
import { benefits, processSteps, sampleSites, services } from '../data/site';
---

<SiteLayout
  title="Webleee | Websites Built, Hosted, and Managed"
  description="Webleee builds, deploys, hosts, and manages modern websites for businesses that want a professional site without technical stress."
>
  <section class="border-b border-line bg-white">
    <div class="site-shell grid items-center gap-12 py-16 lg:grid-cols-[0.92fr_1.08fr] lg:py-24">
      <div class="max-w-3xl">
        <p class="eyebrow">Web design and website management</p>
        <h1 class="mt-6 heading-xl">Websites built, hosted, and managed for growing businesses.</h1>
        <p class="mt-7 max-w-2xl text-lg leading-8 text-slatebody">
          Webleee helps businesses get a professional site live without handling hosting, deployment, DNS, updates, and technical maintenance themselves.
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a href="/contact/" class="btn-primary">Get a free homepage preview</a>
          <a href="/our-work/" class="btn-secondary">View example websites</a>
        </div>
        <div class="mt-10 grid max-w-2xl divide-y divide-line border-y border-line sm:grid-cols-3 sm:divide-x sm:divide-y-0">
          {[
            ['Build', 'Professional website structure and page design.'],
            ['Launch', 'Cloudflare deployment and domain support.'],
            ['Manage', 'Monthly updates, support, and technical care.']
          ].map((item) => (
            <div class="py-5 sm:px-5">
              <p class="font-display text-2xl font-black text-navy">{item[0]}</p>
              <p class="mt-2 text-sm leading-6 text-slatebody">{item[1]}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="border border-line bg-fog p-4 shadow-agency">
        <div class="grid gap-4 sm:grid-cols-[1.1fr_0.9fr]">
          <a href="/our-work/" class="group block overflow-hidden border border-line bg-white">
            <img src="/work/apexbuild.jpg" alt="ApexBuild Construction fictional demo website preview" width="1280" height="900" class="h-72 w-full object-cover object-top transition duration-500 group-hover:scale-105" decoding="async" />
            <div class="p-5">
              <p class="text-xs font-black uppercase tracking-[0.16em] text-electric">Example website</p>
              <h2 class="mt-2 font-display text-2xl font-black text-navy">Contractor website sample</h2>
            </div>
          </a>
          <div class="grid gap-4">
            <a href="/our-work/" class="group block overflow-hidden border border-line bg-white">
              <img src="/work/lumina-dental.jpg" alt="Lumina Dental Studio fictional demo website preview" width="1280" height="900" class="h-40 w-full object-cover object-top transition duration-500 group-hover:scale-105" loading="lazy" decoding="async" />
              <div class="p-4">
                <p class="text-xs font-black uppercase tracking-[0.16em] text-electric">Healthcare</p>
                <h2 class="mt-1 font-display text-xl font-black text-navy">Clinic sample</h2>
              </div>
            </a>
            <div class="bg-navy p-6 text-white">
              <p class="text-xs font-black uppercase tracking-[0.16em] text-lime">Current offer</p>
              <p class="mt-4 font-display text-3xl font-black leading-tight">Build, launch, host, and manage one business website.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-fog py-16">
    <div class="site-shell">
      <div class="grid gap-8 lg:grid-cols-[0.65fr_1.35fr] lg:items-start">
        <SectionHeader
          eyebrow="What businesses get"
          title="A practical website setup handled by one partner."
          copy="The work is not only the page design. Webleee also helps with the launch, hosting setup, and ongoing updates."
        />
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {benefits.map((benefit) => (
          <div class="border border-line bg-white p-4">
            <h3 class="font-display text-lg font-black text-navy">{benefit}</h3>
          </div>
        ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="site-shell">
      <div class="grid gap-10 lg:grid-cols-[0.72fr_1.28fr]">
        <div>
          <SectionHeader
            eyebrow="What Webleee does"
            title="From first preview to a managed live website."
            copy="The goal is simple: make it easier for a business to look professional online without managing technical work alone."
          />
          <a href="/process/" class="mt-8 btn-light">See the full process</a>
        </div>
        <div class="grid gap-4">
        {services.map((service) => (
          <article class="grid gap-5 border-l-4 border-electric bg-fog p-6 sm:grid-cols-[8rem_1fr]">
            <h3 class="font-display text-2xl font-black">{service.title}</h3>
            <p class="text-sm leading-7 text-slatebody">{service.copy}</p>
          </article>
        ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-midnight py-20 text-white">
    <div class="site-shell">
      <div class="flex flex-col justify-between gap-6 lg:flex-row lg:items-end">
        <SectionHeader
          eyebrow="Example websites"
          title="Explore sample websites built to show different business styles."
          copy="These are fictional sample websites created by Webleee to show layout, tone, and industry direction."
          light
        />
        <a href="/our-work/" class="btn-on-dark self-start lg:self-auto">View example websites</a>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {sampleSites.slice(0, 6).map((site) => <PortfolioCard site={site} featured />)}
      </div>
    </div>
  </section>

  <section class="bg-navy py-20 text-white">
    <div class="site-shell">
      <SectionHeader
        eyebrow="Process overview"
        title="A straightforward path from idea to live website."
        copy="You stay focused on your business while Webleee handles the structure, build, launch, and management."
        light
      />
      <div class="mt-10 grid gap-5 lg:grid-cols-5">
        {processSteps.map((step, index) => (
          <article class="rounded-lg border border-white/10 bg-white/7 p-6">
            <p class="font-display text-4xl font-black text-lime">{index + 1}</p>
            <h3 class="mt-5 font-display text-xl font-black">{step.title}</h3>
            <p class="mt-4 text-sm leading-7 text-white/62">{step.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-fog py-20">
    <div class="site-shell">
      <div class="mb-10 flex flex-col justify-between gap-6 lg:flex-row lg:items-end">
        <SectionHeader
          eyebrow="Pricing overview"
          title="Plans for different business stages."
          copy="Exact pricing should be confirmed after Webleee understands the website size, content needs, update needs, and support level."
        />
        <a href="/pricing/" class="btn-light self-start lg:self-auto">Compare website plans</a>
      </div>
      <PricingCards />
    </div>
  </section>

  <CTA />
</SiteLayout>
