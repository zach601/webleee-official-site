---
import SiteLayout from '../layouts/SiteLayout.astro';
import PortfolioCard from '../components/PortfolioCard.astro';
import PricingCards from '../components/PricingCards.astro';
import CTA from '../components/CTA.astro';
import { processSteps, sampleSites, services } from '../data/site';

const featuredSites = sampleSites.slice(0, 3);
const directorySites = sampleSites.slice(3);
const buildBoard = [
  ['01', 'Business brief', 'Services, audience, goals, photos, domain details, and required pages.'],
  ['02', 'Homepage direction', 'A practical first pass so the business can review structure and tone before the full build.'],
  ['03', 'Launch setup', 'Static build, Cloudflare deployment, DNS support, metadata, and basic technical polish.'],
  ['04', 'Monthly desk', 'Updates, support, hosting management, content changes, and ongoing website care.'],
];
---

<SiteLayout
  title="Webleee | Websites Built, Hosted, and Managed"
  description="Webleee builds, deploys, hosts, and manages modern websites for businesses that want a professional site without technical stress."
>
  <section class="relative overflow-hidden bg-midnight text-white">
    <div class="absolute inset-0 bg-[linear-gradient(135deg,#030812_0%,#07111f_46%,#0d1d38_100%)]"></div>
    <div class="absolute left-0 top-0 hidden h-full w-24 border-r border-white/10 bg-white/[0.03] lg:block"></div>
    <div class="site-shell relative grid min-h-[calc(100vh-76px)] gap-12 py-12 lg:grid-cols-[0.86fr_1.14fr] lg:items-center lg:py-16">
      <div>
        <p class="text-xs font-black uppercase tracking-[0.2em] text-lime">Webleee website studio</p>
        <h1 class="mt-6 heading-xl">Websites built, hosted, and managed for growing businesses.</h1>
        <p class="mt-7 max-w-2xl text-lg leading-8 text-white/70">
          Webleee helps businesses move from “we need a better website” to a launched, hosted, managed site without handling the technical setup alone.
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a href="/contact/" class="btn-primary">Get a free homepage preview</a>
          <a href="/our-work/" class="btn-secondary">View example websites</a>
        </div>
        <div class="mt-10 grid max-w-2xl border-y border-white/10 sm:grid-cols-3">
          {['Build the site', 'Launch it fast', 'Manage it monthly'].map((item) => (
            <div class="border-white/10 py-5 sm:border-r sm:px-5 first:sm:pl-0 last:sm:border-r-0">
              <p class="font-black text-white">{item}</p>
              <p class="mt-1 text-xs font-bold uppercase tracking-[0.14em] text-white/45">Webleee handles it</p>
            </div>
          ))}
        </div>
      </div>

      <div class="relative">
        <div class="grid gap-4 lg:grid-cols-[0.74fr_0.26fr]">
          <div class="overflow-hidden rounded-[34px] border border-white/12 bg-white p-3 shadow-agency">
            <div class="flex items-center justify-between rounded-2xl bg-fog px-4 py-3 text-navy">
              <span class="text-sm font-black">Example website board</span>
              <span class="rounded-lg bg-lime px-3 py-1 text-xs font-black uppercase tracking-[0.14em] text-midnight">Live previews</span>
            </div>
            <div class="mt-3 grid gap-3 sm:grid-cols-2">
              {featuredSites.map((site) => (
                <a href={site.url} target="_blank" rel="noopener noreferrer" class="group overflow-hidden rounded-2xl bg-navy text-white">
                  <img src={site.image} alt={site.imageAlt} width="1280" height="900" class="h-52 w-full object-cover object-top opacity-90 transition duration-500 group-hover:scale-105 sm:h-64" decoding="async" />
                  <div class="p-4">
                    <p class="text-xs font-black uppercase tracking-[0.14em] text-lime">{site.industry}</p>
                    <h2 class="mt-2 font-display text-xl font-black">{site.name}</h2>
                  </div>
                </a>
              ))}
              <div class="rounded-2xl bg-midnight p-5 text-white">
                <p class="text-xs font-black uppercase tracking-[0.16em] text-lime">Portfolio note</p>
                <p class="mt-4 text-2xl font-black leading-tight">Sample websites, not client case studies.</p>
                <p class="mt-4 text-sm leading-6 text-white/62">Created to show layout, tone, and industry direction.</p>
              </div>
            </div>
          </div>
          <div class="grid gap-4">
            {['Design', 'Deploy', 'Host', 'Update'].map((item) => (
              <div class="rounded-2xl border border-white/12 bg-white/8 p-5">
                <p class="text-xs font-black uppercase tracking-[0.16em] text-lime">Included</p>
                <p class="mt-2 font-display text-2xl font-black">{item}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="site-shell">
      <div class="grid gap-8 lg:grid-cols-[0.72fr_1.28fr] lg:items-end">
        <div>
          <p class="eyebrow">See what Webleee can build</p>
          <h2 class="mt-4 heading-lg">Different industries should not all look like the same template.</h2>
        </div>
        <p class="max-w-3xl text-lg leading-8 text-slatebody lg:justify-self-end">
          These sample websites show how Webleee can change layout, tone, imagery, and conversion flow for different business types. They are fictional examples, not real client projects.
        </p>
      </div>

      <div class="mt-12 grid gap-6 lg:grid-cols-[1.15fr_0.85fr]">
        <div class="grid gap-6 sm:grid-cols-2">
          {featuredSites.map((site) => <PortfolioCard site={site} featured />)}
          <a href="/our-work/" class="flex min-h-64 flex-col justify-between rounded-3xl bg-midnight p-7 text-white transition hover:-translate-y-1">
            <span class="text-xs font-black uppercase tracking-[0.18em] text-lime">Full work page</span>
            <span class="font-display text-4xl font-black leading-tight">View all example websites</span>
          </a>
        </div>
        <div class="rounded-[34px] border border-line bg-fog p-5">
          <p class="px-2 text-xs font-black uppercase tracking-[0.18em] text-electric">Website sample index</p>
          <div class="mt-4 divide-y divide-line overflow-hidden rounded-2xl border border-line bg-white">
            {directorySites.map((site) => (
              <a href={site.url} target="_blank" rel="noopener noreferrer" class="grid gap-4 p-5 transition hover:bg-skywash sm:grid-cols-[96px_1fr]">
                <img src={site.image} alt={site.imageAlt} width="1280" height="900" loading="lazy" decoding="async" class="h-24 w-full rounded-xl object-cover object-top sm:w-24" />
                <span>
                  <span class="block text-xs font-black uppercase tracking-[0.14em] text-electric">{site.industry}</span>
                  <span class="mt-1 block font-display text-xl font-black text-navy">{site.name}</span>
                  <span class="mt-2 block text-sm leading-6 text-slatebody">{site.style}</span>
                </span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-fog py-20">
    <div class="site-shell">
      <div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr]">
        <div class="lg:sticky lg:top-28 lg:self-start">
          <p class="eyebrow">What Webleee does</p>
          <h2 class="mt-4 heading-lg">One service path: build, launch, host, and keep it current.</h2>
          <p class="mt-5 text-lg leading-8 text-slatebody">
            Most businesses do not want a pile of technical tasks. Webleee packages the website work into a practical managed setup.
          </p>
          <a href="/process/" class="mt-8 btn-light">See the full process</a>
        </div>
        <div class="grid gap-4">
          {services.map((service, index) => (
            <article class="grid gap-5 border-l-4 border-electric bg-white p-6 shadow-sm sm:grid-cols-[88px_1fr]">
              <p class="font-display text-5xl font-black text-navy/16">{String(index + 1).padStart(2, '0')}</p>
              <div>
                <h3 class="font-display text-3xl font-black text-navy">{service.title}</h3>
                <p class="mt-3 max-w-2xl text-base leading-7 text-slatebody">{service.copy}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="site-shell">
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
        <div>
          <p class="eyebrow">From idea to live website</p>
          <h2 class="mt-4 heading-lg">A simple production flow businesses can understand.</h2>
          <p class="mt-5 text-lg leading-8 text-slatebody">
            Webleee turns business details into a reviewable website direction, then handles the launch and ongoing management once the scope is approved.
          </p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {buildBoard.map(([number, title, copy]) => (
            <article class="rounded-3xl border border-line bg-white p-6 shadow-sm">
              <p class="text-sm font-black text-electric">{number}</p>
              <h3 class="mt-4 font-display text-2xl font-black text-navy">{title}</h3>
              <p class="mt-3 text-sm leading-7 text-slatebody">{copy}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="mt-14 grid overflow-hidden rounded-[34px] border border-line lg:grid-cols-2">
        <div class="bg-fog p-7 lg:p-9">
          <p class="text-xs font-black uppercase tracking-[0.18em] text-slatebody">Before</p>
          <h3 class="mt-4 font-display text-4xl font-black text-navy">A business needs a clearer website.</h3>
          <ul class="mt-6 space-y-3 text-sm font-semibold text-slatebody">
            <li>Unclear pages or no modern website</li>
            <li>Hosting and domain questions</li>
            <li>No simple update path after launch</li>
          </ul>
        </div>
        <div class="bg-midnight p-7 text-white lg:p-9">
          <p class="text-xs font-black uppercase tracking-[0.18em] text-lime">After</p>
          <h3 class="mt-4 font-display text-4xl font-black">A launched site with monthly management.</h3>
          <ul class="mt-6 space-y-3 text-sm font-semibold text-white/72">
            <li>Clear pages and conversion paths</li>
            <li>Cloudflare-compatible static deployment</li>
            <li>Ongoing changes, support, and technical care</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-fog py-20">
    <div class="site-shell">
      <div class="mb-10 grid gap-8 lg:grid-cols-[0.75fr_1fr] lg:items-end">
        <div>
          <p class="eyebrow">Website plans</p>
          <h2 class="mt-4 heading-lg">Productized enough to be clear. Flexible enough to fit the scope.</h2>
        </div>
        <p class="text-lg leading-8 text-slatebody">
          Pricing depends on page count, content needs, form setup, launch support, and monthly management. Exact terms should be confirmed before work starts.
        </p>
      </div>
      <PricingCards />
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="site-shell">
      <div class="grid gap-6 lg:grid-cols-5">
        {processSteps.map((step, index) => (
          <article class="border-t-4 border-electric bg-fog p-5">
            <p class="font-display text-4xl font-black text-navy">{index + 1}</p>
            <h3 class="mt-5 font-display text-xl font-black text-navy">{step.title}</h3>
            <p class="mt-3 text-sm leading-7 text-slatebody">{step.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</SiteLayout>
