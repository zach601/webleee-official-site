---
import SiteLayout from '../layouts/SiteLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PortfolioCard from '../components/PortfolioCard.astro';
import CTA from '../components/CTA.astro';
import { benefits, pricingPlans, processSteps, sampleSites, services } from '../data/site';
---

<SiteLayout
  title="Webleee | Websites Built, Hosted, and Managed"
  description="Webleee builds, deploys, hosts, and manages modern websites for businesses that want a professional site without technical stress."
>
  <section class="border-b border-line bg-white">
    <div class="site-shell grid items-center gap-12 py-16 lg:grid-cols-[0.95fr_0.85fr] lg:py-24">
      <div class="max-w-3xl">
        <p class="eyebrow">Web design and website management</p>
        <h1 class="mt-6 heading-xl">Websites built, hosted, and managed for growing businesses.</h1>
        <p class="mt-7 max-w-2xl text-lg leading-8 text-slatebody">
          Webleee helps businesses get a professional site live without handling hosting, deployment, DNS, updates, and technical maintenance themselves.
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a href="/contact/" class="btn-primary">Start your website</a>
          <a href="/our-work/" class="btn-secondary">View sample websites</a>
        </div>
        <div class="mt-10 grid max-w-2xl divide-y divide-line border-y border-line sm:grid-cols-3 sm:divide-x sm:divide-y-0">
          {[
            ['Build', 'Professional website structure and page design.'],
            ['Launch', 'Cloudflare deployment and domain support.'],
            ['Manage', 'Monthly updates, support, and technical care.']
          ].map((item) => (
            <div class="py-5 sm:px-5">
              <p class="font-display text-2xl font-black text-navy">{item[0]}</p>
              <p class="mt-2 text-sm leading-6 text-slatebody">{item[1]}</p>
            </div>
          ))}
        </div>
      </div>
      <aside class="rounded-xl border border-line bg-fog p-4 shadow-agency" aria-label="Website enquiry form">
        <form class="rounded-lg bg-white p-6 text-navy sm:p-8">
          <div class="mb-6">
            <p class="eyebrow">Start here</p>
            <h2 class="mt-3 font-display text-3xl font-black leading-tight">Tell us about your website</h2>
            <p class="mt-3 text-sm leading-7 text-slatebody">
              Share the basics and Webleee can understand the build, launch setup, and monthly management needs. This form is UI-only until a backend is connected.
            </p>
          </div>
          <div class="grid gap-4">
            <div>
              <label for="home-name" class="text-sm font-black">Name</label>
              <input id="home-name" name="name" type="text" placeholder="Your name" class="mt-2 min-h-12 w-full rounded-lg border border-line bg-fog px-4 text-sm outline-none focus:border-electric focus:ring-4 focus:ring-lime/35" />
            </div>
            <div>
              <label for="home-business" class="text-sm font-black">Business name</label>
              <input id="home-business" name="business" type="text" placeholder="Business name" class="mt-2 min-h-12 w-full rounded-lg border border-line bg-fog px-4 text-sm outline-none focus:border-electric focus:ring-4 focus:ring-lime/35" />
            </div>
            <div>
              <label for="home-email" class="text-sm font-black">Email</label>
              <input id="home-email" name="email" type="email" placeholder="Your email address" class="mt-2 min-h-12 w-full rounded-lg border border-line bg-fog px-4 text-sm outline-none focus:border-electric focus:ring-4 focus:ring-lime/35" />
            </div>
            <div>
              <label for="home-project" class="text-sm font-black">Website needed</label>
              <select id="home-project" name="website_type" class="mt-2 min-h-12 w-full rounded-lg border border-line bg-fog px-4 text-sm outline-none focus:border-electric focus:ring-4 focus:ring-lime/35">
                <option>Business website</option>
                <option>Website redesign</option>
                <option>Contractor / trades website</option>
                <option>Professional services website</option>
                <option>Restaurant / hospitality website</option>
                <option>Product / catalogue website</option>
              </select>
            </div>
          </div>
          <button type="button" class="mt-6 inline-flex min-h-12 w-full items-center justify-center rounded-lg border border-line bg-fog px-6 py-3 text-sm font-black text-slatebody">
            Form not connected yet
          </button>
          <p class="mt-4 text-xs leading-6 text-slatebody">
            Connect the form backend before using this for live enquiries.
          </p>
        </form>
      </aside>
    </div>
  </section>

  <section class="bg-fog py-16">
    <div class="site-shell">
      <div class="grid gap-8 lg:grid-cols-[0.72fr_1.28fr] lg:items-start">
        <SectionHeader
          eyebrow="What businesses get"
          title="The practical pieces a business website needs."
          copy="The essentials are kept simple here. Deeper details live on the pricing, process, and contact pages."
        />
        <div>
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {benefits.slice(0, 6).map((benefit) => (
              <div class="border border-line bg-white p-4">
                <h3 class="font-display text-lg font-black text-navy">{benefit}</h3>
              </div>
            ))}
          </div>
          <a href="/process/" class="mt-6 btn-light">See how Webleee works</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="site-shell">
      <div class="grid gap-10 lg:grid-cols-[0.72fr_1.28fr]">
        <div>
          <SectionHeader
            eyebrow="What Webleee does"
            title="Build, launch, host, and manage."
            copy="A simple service model for businesses that want one partner handling the website instead of juggling design, hosting, DNS, and updates."
          />
          <a href="/process/" class="mt-8 btn-light">See the full process</a>
        </div>
        <div class="grid gap-4">
        {services.slice(0, 3).map((service) => (
          <article class="grid gap-5 border-l-4 border-electric bg-fog p-6 sm:grid-cols-[8rem_1fr]">
            <h3 class="font-display text-2xl font-black">{service.title}</h3>
            <p class="text-sm leading-7 text-slatebody">{service.copy}</p>
          </article>
        ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-midnight py-20 text-white">
    <div class="site-shell">
      <div class="flex flex-col justify-between gap-6 lg:flex-row lg:items-end">
        <SectionHeader
          eyebrow="Sample websites"
          title="Explore sample websites built to show different business styles."
          copy="A few samples are shown here. The full Our Work page has all six industry examples."
          light
        />
        <a href="/our-work/" class="btn-on-dark self-start lg:self-auto">Show all sample websites</a>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {sampleSites.slice(0, 3).map((site) => <PortfolioCard site={site} featured />)}
      </div>
    </div>
  </section>

  <section class="bg-navy py-20 text-white">
    <div class="site-shell">
      <SectionHeader
        eyebrow="Process overview"
        title="A straightforward path from idea to live website."
        copy="You stay focused on your business while Webleee handles the structure, build, launch, and management."
        light
      />
      <div class="mt-10 grid gap-5 lg:grid-cols-3">
        {processSteps.slice(0, 3).map((step, index) => (
          <article class="rounded-lg border border-white/10 bg-white/7 p-6">
            <p class="font-display text-4xl font-black text-lime">{index + 1}</p>
            <h3 class="mt-5 font-display text-xl font-black">{step.title}</h3>
            <p class="mt-4 text-sm leading-7 text-white/62">{step.copy}</p>
          </article>
        ))}
      </div>
      <a href="/process/" class="mt-8 btn-on-dark">See all process steps</a>
    </div>
  </section>

  <section class="bg-fog py-20">
    <div class="site-shell">
      <div class="mb-10 flex flex-col justify-between gap-6 lg:flex-row lg:items-end">
        <SectionHeader
          eyebrow="Pricing overview"
          title="Plans for different business stages."
          copy="Exact pricing should be confirmed after Webleee understands the website size, content needs, update needs, and support level."
        />
        <a href="/pricing/" class="btn-light self-start lg:self-auto">Compare website plans</a>
      </div>
      <div class="grid gap-5 lg:grid-cols-3">
        {pricingPlans.map((plan) => (
          <article class={`rounded-lg border p-6 ${plan.highlighted ? 'border-electric bg-navy text-white' : 'border-line bg-white text-navy'}`}>
            <p class={`text-xs font-black uppercase tracking-[0.16em] ${plan.highlighted ? 'text-lime' : 'text-electric'}`}>Plan option</p>
            <h3 class="mt-4 font-display text-2xl font-black">{plan.name}</h3>
            <p class={`mt-4 text-sm leading-7 ${plan.highlighted ? 'text-white/68' : 'text-slatebody'}`}>{plan.fit}</p>
            <p class="mt-5 font-display text-2xl font-black">{plan.price}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</SiteLayout>
