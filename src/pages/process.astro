---
import SiteLayout from '../layouts/SiteLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CTA from '../components/CTA.astro';

const fullProcess = [
  {
    title: 'Request a website',
    copy: 'The business contacts Webleee and explains what they need, what industry they are in, and what the website should help customers do.',
  },
  {
    title: 'Share business details',
    copy: 'The business sends their logo, services, contact details, photos, domain information, goals, and any existing website links.',
  },
  {
    title: 'Webleee creates a website preview',
    copy: 'Webleee creates an initial website preview for review, usually starting with a homepage direction and key content structure.',
  },
  {
    title: 'Review and changes',
    copy: 'The business checks the preview and requests changes to content, sections, tone, visuals, and calls to action.',
  },
  {
    title: 'Launch',
    copy: 'Webleee deploys the website, checks the production build, and connects the domain once the site is approved.',
  },
  {
    title: 'Monthly management',
    copy: 'Webleee hosts, manages, updates, and supports the website monthly so the business does not have to handle the technical side alone.',
  },
];
---

<SiteLayout
  title="Process | Webleee"
  description="Learn how Webleee takes a business website from request and preview to launch, hosting, and monthly management."
>
  <section class="bg-midnight py-20 text-white">
    <div class="site-shell">
      <p class="text-xs font-black uppercase tracking-[0.18em] text-lime">Process</p>
      <h1 class="mt-5 max-w-4xl font-display text-5xl font-black leading-tight sm:text-6xl">A clear website process from request to monthly management.</h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-white/68">
        Webleee keeps the website process simple for businesses: share the details, review the preview, approve the build, launch, then keep improving.
      </p>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="site-shell">
      <SectionHeader
        eyebrow="How it works"
        title="Six practical stages."
        copy="Each stage is designed to make the website build easier to understand and easier to manage."
      />
      <div class="mt-12 space-y-5">
        {fullProcess.map((step, index) => (
          <article class="grid gap-5 rounded-[30px] border border-line bg-white p-6 shadow-sm lg:grid-cols-[120px_1fr] lg:items-center">
            <p class="font-display text-5xl font-black text-electric">{String(index + 1).padStart(2, '0')}</p>
            <div>
              <h2 class="font-display text-3xl font-black">{step.title}</h2>
              <p class="mt-3 max-w-3xl text-base leading-7 text-slatebody">{step.copy}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-fog py-20">
    <div class="site-shell grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="eyebrow">What to prepare</p>
        <h2 class="mt-4 heading-lg">The better the input, the stronger the preview.</h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {['Logo or brand name', 'Services or offers', 'Business contact details', 'Photos or preferred image style', 'Domain details if available', 'Goals for the website'].map((item) => (
          <div class="rounded-2xl border border-line bg-white p-5 font-bold text-navy">{item}</div>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</SiteLayout>
