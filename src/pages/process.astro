---
import SiteLayout from '../layouts/SiteLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CTA from '../components/CTA.astro';

const fullProcess = [
  {
    title: 'Send business details',
    copy: 'The business contacts Webleee and explains what they do, who they serve, what kind of website they need, and what the website should help customers do.',
  },
  {
    title: 'Share content and access',
    copy: 'The business sends available logo files, services, contact details, photos, domain information, goals, and any existing website links.',
  },
  {
    title: 'Webleee creates a homepage preview or proposal',
    copy: 'Webleee prepares a practical first direction for review, usually starting with a homepage structure and key content plan.',
  },
  {
    title: 'Review and request changes',
    copy: 'The business checks the homepage preview or proposal and Webleee adjusts the layout, copy, visuals, sections, and calls to action based on the agreed scope.',
  },
  {
    title: 'Launch and monthly management',
    copy: 'Once approved, Webleee deploys the website, connects the domain, and manages the site monthly so the business does not have to handle the technical side alone.',
  },
];
---

<SiteLayout
  title="Process | Webleee"
  description="Learn how Webleee takes a business website from enquiry and homepage preview to launch, hosting, and monthly management."
>
  <section class="bg-midnight py-20 text-white">
    <div class="site-shell grid gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-center">
      <div>
        <p class="text-xs font-black uppercase tracking-[0.18em] text-lime">Process</p>
        <h1 class="mt-5 font-display text-5xl font-black leading-tight sm:text-6xl">From request to launched website, without mystery steps.</h1>
      </div>
      <div class="rounded-[32px] border border-white/10 bg-white/7 p-6">
        <p class="text-lg leading-8 text-white/72">
          Webleee keeps the website process simple for businesses: share the details, review the homepage preview or proposal, approve the build, launch, then keep improving.
        </p>
        <a href="/contact/" class="mt-8 btn-primary">Get a free homepage preview</a>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="site-shell">
      <SectionHeader
        eyebrow="How it works"
        title="Five practical stages."
        copy="Each stage is designed to make the website build easier to understand and easier to manage."
      />
      <div class="mt-12 space-y-5 border-l-4 border-electric pl-5">
        {fullProcess.map((step, index) => (
          <article class="grid gap-5 bg-fog p-6 lg:grid-cols-[120px_1fr] lg:items-center">
            <p class="font-display text-5xl font-black text-electric">{String(index + 1).padStart(2, '0')}</p>
            <div>
              <h2 class="font-display text-3xl font-black">{step.title}</h2>
              <p class="mt-3 max-w-3xl text-base leading-7 text-slatebody">{step.copy}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-fog py-20">
    <div class="site-shell grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="eyebrow">What to prepare</p>
        <h2 class="mt-4 heading-lg">The better the input, the stronger the preview.</h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {['Logo or brand name', 'Services or offers', 'Business contact details', 'Photos or preferred image style', 'Domain details if available', 'Goals for the website'].map((item) => (
          <div class="rounded-2xl border border-line bg-white p-5 font-bold text-navy">{item}</div>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</SiteLayout>
