---
import '../styles/global.css';
import { navItems } from '../data/site';

const {
  title = 'Webleee | Websites Built, Hosted, and Managed',
  description = 'Webleee builds, deploys, hosts, and manages modern websites for businesses.',
  image = '/og-image.jpg',
  imageAlt = 'Webleee builds, hosts, and manages websites for businesses',
  structuredData = [],
  noindex = false,
} = Astro.props;

const siteUrl = 'https://www.webleee.com';
const currentPath = Astro.url.pathname;
const canonicalUrl = new URL(currentPath, siteUrl).toString();
const ogImageUrl = new URL(image, siteUrl).toString();
const structuredDataItems = Array.isArray(structuredData) ? structuredData : [structuredData];
const organizationStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Webleee',
  url: siteUrl,
  description: 'Webleee builds, hosts, deploys, and manages modern websites for businesses.',
};
const allStructuredData = [organizationStructuredData, ...structuredDataItems.filter(Boolean)];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Webleee" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <meta name="theme-color" content="#030812" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    {allStructuredData.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body>
    <header class="sticky top-0 z-50 border-b border-white/10 bg-midnight text-white">
      <nav class="site-shell flex min-h-20 items-center justify-between gap-5 py-4" aria-label="Main navigation">
        <a href="/" class="flex items-center gap-3">
          <span class="relative grid h-11 w-11 place-items-center rounded-2xl bg-electric font-black text-white shadow-glow" aria-hidden="true">
            W
            <span class="absolute -right-1 -top-1 h-3 w-3 rounded-full bg-lime"></span>
          </span>
          <span>
            <span class="block font-display text-xl font-black leading-none">Webleee</span>
            <span class="block text-xs font-bold uppercase tracking-[0.16em] text-white/70">Build. Host. Manage.</span>
          </span>
        </a>
        <div class="hidden items-center gap-1 rounded-full border border-white/10 bg-white/7 p-2 lg:flex">
          {navItems.map((item) => {
            const active = item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href);
            return (
              <a
                href={item.href}
                class={`rounded-full px-4 py-2 text-sm font-bold transition ${active ? 'bg-white text-navy' : 'text-white/72 hover:bg-white/10 hover:text-white'}`}
              >
                {item.label}
              </a>
            );
          })}
        </div>
        <a href="/contact/" class="hidden rounded-full bg-white px-5 py-3 text-sm font-black text-navy transition hover:-translate-y-0.5 hover:bg-lime lg:inline-flex">
          Get a free homepage preview
        </a>
      </nav>
      <div class="site-shell flex gap-2 overflow-x-auto pb-4 lg:hidden" aria-label="Mobile navigation">
        {navItems.map((item) => (
          <a href={item.href} class="shrink-0 rounded-full border border-white/10 bg-white/8 px-4 py-2 text-sm font-bold text-white/75">
            {item.label}
          </a>
        ))}
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="bg-midnight text-white">
      <div class="site-shell grid gap-10 py-14 lg:grid-cols-[1.1fr_0.8fr_0.8fr_0.9fr]">
        <div>
          <a href="/" class="flex items-center gap-3">
            <span class="relative grid h-11 w-11 place-items-center rounded-2xl bg-electric font-black text-white" aria-hidden="true">
              W
              <span class="absolute -right-1 -top-1 h-3 w-3 rounded-full bg-lime"></span>
            </span>
            <span class="font-display text-2xl font-black">Webleee</span>
          </a>
          <p class="mt-5 max-w-md text-sm leading-7 text-white/62">
            Webleee builds, deploys, hosts, and manages modern websites for businesses that want a professional web presence without handling the technical side.
          </p>
          <p class="mt-5 text-sm font-black text-white">Websites built and managed by Webleee</p>
          <p class="mt-3 max-w-lg text-xs leading-6 text-white/62">
            Portfolio examples are fictional demo websites created to show what Webleee can build.
          </p>
        </div>
        <div>
          <h2 class="text-sm font-black uppercase tracking-[0.16em] text-white">Pages</h2>
          <div class="mt-5 grid gap-3">
            {navItems.map((item) => (
              <a href={item.href} class="text-sm font-semibold text-white/62 transition hover:text-lime">{item.label}</a>
            ))}
          </div>
        </div>
        <div>
          <h2 class="text-sm font-black uppercase tracking-[0.16em] text-white">Legal</h2>
          <div class="mt-5 grid gap-3">
            <a href="/privacy-policy/" class="text-sm font-semibold text-white/62 transition hover:text-lime">Privacy Policy</a>
            <a href="/terms-of-service/" class="text-sm font-semibold text-white/62 transition hover:text-lime">Terms of Service</a>
          </div>
          <a href="/contact/" class="mt-6 inline-flex min-h-12 items-center justify-center rounded-full bg-lime px-5 py-3 text-sm font-black text-midnight transition hover:-translate-y-0.5 hover:bg-white">
            Get a free homepage preview
          </a>
        </div>
        <div>
          <h2 class="text-sm font-black uppercase tracking-[0.16em] text-white">Contact Details</h2>
          <div class="mt-5 space-y-3 text-sm leading-6 text-white/62">
            <p>Email: To be added</p>
            <p>WhatsApp: Contact details coming soon</p>
            <p>Website: www.webleee.com</p>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
